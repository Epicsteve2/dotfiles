ANTIDOTE_DIR=${ZDOTDIR:-$HOME}/.antidote
if [[ ! -e $ANTIDOTE_DIR/antidote.zsh ]]; then
    git clone --depth=1 https://github.com/mattmc3/antidote.git $ANTIDOTE_DIR
fi

_sitefns=${XDG_DATA_HOME:-$HOME/.local/share}/zsh/site-functions
mkdir -p $_sitefns
fpath=($_sitefns $fpath)

autoload -Uz compinit
# full rebuild + security scan only if the dump is >24h old; otherwise trust it (fast -C path).
# extended_glob (scoped local) is required for the (#q...) qualifier to parse, else the test
# is always true and the -C fast path is never taken.
() {
  setopt local_options extended_glob
  if [[ -n ${ZDOTDIR:-$HOME}/.zcompdump(#qN.mh+24) ]]; then
    compinit
  else
    compinit -C
  fi
}
autoload -Uz bashcompinit && bashcompinit

# zsh-vi-mode hook functions must be defined before the plugin loads
function zvm_config() {
  ZVM_LINE_INIT_MODE=$ZVM_MODE_INSERT
  ZVM_SYSTEM_CLIPBOARD_ENABLED=true
}
function zvm_after_init() {
  eval "$(atuin init zsh)"

  bindkey " " globalias

  # home and end
  bindkey  "^[[H"   beginning-of-line
  bindkey  "^[[F"   end-of-line
  # delete key
  bindkey "^[[3~" delete-char

  # idk lol
  bindkey "^[[1;5C" forward-word
  bindkey "^[[1;5D" backward-word
  bindkey "\C-h" backward-kill-word
  bindkey "\e[3;5~" kill-word
  # bindkey "^[[1;3C" forward-word      # Option+Right for macOS
  # bindkey "^[[1;3D" backward-word     # Option+Left for macOS
  # bindkey "^[^?" backward-kill-word   # Option+Backspace (delete word backward) for macOS
  # bindkey "^[[3;3~" kill-word         # Option+Delete (delete word forward) for macOS
}

function zvm_after_lazy_keybindings() {
  bindkey -M vicmd '_' vi-first-non-blank
  bindkey -M visual '_' vi-first-non-blank
}

zsh_plugins=${ZDOTDIR:-$HOME}/.zsh_plugins
if [[ ! ${zsh_plugins}.zsh -nt ${zsh_plugins}.txt ]]; then
  source $ANTIDOTE_DIR/antidote.zsh
  antidote bundle <${zsh_plugins}.txt >${zsh_plugins}.zsh
fi
source ${zsh_plugins}.zsh

eval "$(starship init zsh --print-full-init)"
eval "$(zoxide init zsh)"

zstyle ':notify:*' expire-time 15000

zstyle ':fzf-tab:*' fzf-bindings 'tab:accept'
zstyle ':fzf-tab:*' continuous-trigger shift-tab
zstyle ':fzf-tab:*' accept-line enter

# TODO: can get lesspipe and other stuff to make completions better https://github.com/Freed-Wu/fzf-tab-source

# # Case insensitive https://superuser.com/questions/1092033/how-can-i-make-zsh-tab-completion-fix-capitalization-errors-for-directories-and
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}'

export HISTFILE="${HOME}/.zsh_history"
export HISTSIZE=100000
export SAVEHIST=$HISTSIZE

# setopt BANG_HIST                 # Treat the '!' character specially during expansion.
